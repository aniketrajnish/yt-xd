{
  "id": "com.local.ap-thumbnailer",
  "name": "AP Thumbnailer",
  "version": "1.0.0",
  "main": "xd-plugin/ap-thumbnail-panel.js",
  "manifestVersion": 4,
  "host": {
    "app": "XD",
    "minVersion": "36.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "thumbnailPanel",
      "label": "AP Thumbnailer",
      "minimumSize": {
        "width": 280,
        "height": 420
      },
      "maximumSize": {
        "width": 520,
        "height": 900
      }
    }
  ]
}
